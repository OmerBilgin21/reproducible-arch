#!/usr/bin/env bash

target="$(
  tmux list-windows -a -F $'#{session_name}:#{window_index}\t#{pane_current_command}\t#{pane_current_path}' |
    awk -F '\t' '{
      n = split($3, parts, "/")
      dir = parts[n]
      if (dir == "") dir = $3
      print $1 "\t" $2 "\t" dir
    }' |
    fzf \
      --prompt='window> ' \
      --delimiter='\t' \
      --with-nth=1,2,3 \
      --no-hscroll
)"

[ -z "$target" ] && exit 0

window_target="$(printf '%s' "$target" | cut -f1)"
session_target="${window_target%%:*}"

tmux switch-client -t "$session_target" \; select-window -t "$window_target"
